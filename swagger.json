{
  "openapi": "3.0.0",
  "info": {
    "title": "PickUp Logistics API",
    "version": "1.0.0",
    "description": "API documentation for PickUp Logistics backend"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api/v1/shipments": {
      "post": {
        "summary": "Create a shipment",
        "tags": ["Shipments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": {
                    "type": "string",
                    "example": "65f0c8ac4a8f25f0e6be2b39"
                  },
                  "pickupAddress": {
                    "type": "string",
                    "example": "12 Allen Avenue, Ikeja"
                  },
                  "dropoffAddress": {
                    "type": "string",
                    "example": "45 Admiralty Way, Lekki"
                  },
                  "packageType": {
                    "type": "string",
                    "example": "Documents"
                  },
                  "pickupWindowStart": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-20T09:00:00.000Z"
                  },
                  "pickupWindowEnd": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-20T12:00:00.000Z"
                  },
                  "weight": {
                    "type": "number",
                    "example": 2
                  },
                  "price": {
                    "type": "number",
                    "example": 5000
                  },
                  "currency": {
                    "type": "string",
                    "example": "NGN"
                  }
                },
                "required": [
                  "userId",
                  "pickupAddress",
                  "dropoffAddress",
                  "packageType",
                  "weight",
                  "price"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Shipment created successfully"
          },
          "400": {
            "description": "Invalid shipment payload"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/api/v1/shipments/history/{userId}": {
      "get": {
        "summary": "Get shipment history for a user",
        "tags": ["Shipments"],
        "parameters": [
          {
            "in": "path",
            "name": "userId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Shipment history retrieved successfully"
          }
        }
      }
    },
    "/api/v1/shipments/{shipmentId}/cancel": {
      "patch": {
        "summary": "Cancel a shipment",
        "tags": ["Shipments"],
        "parameters": [
          {
            "in": "path",
            "name": "shipmentId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string",
                    "example": "Customer changed mind"
                  }
                },
                "required": ["reason"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipment cancelled successfully"
          },
          "400": {
            "description": "Shipment cannot be cancelled"
          },
          "404": {
            "description": "Shipment not found"
          }
        }
      }
    },
    "/api/v1/shipments/{shipmentId}/invoice": {
      "get": {
        "summary": "Generate invoice for a shipment",
        "tags": ["Shipments"],
        "parameters": [
          {
            "in": "path",
            "name": "shipmentId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice generated successfully"
          }
        }
      }
    },
    "/api/v1/admin/shipments": {
      "get": {
        "summary": "Get all shipments for admin monitoring",
        "tags": ["Admin"],
        "responses": {
          "200": {
            "description": "Admin shipment list retrieved successfully"
          }
        }
      }
    },
    "/api/v1/admin/shipments/{shipmentId}": {
      "get": {
        "summary": "Get single shipment for admin",
        "tags": ["Admin"],
        "parameters": [
          {
            "in": "path",
            "name": "shipmentId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Shipment retrieved successfully"
          },
          "404": {
            "description": "Shipment not found"
          }
        }
      }
    }
  }
}
